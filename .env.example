# PHENODAG environment configuration example
# Copy this file to .env and adjust for your local / deployment environment.
# DO NOT commit secrets to version control.

# Database
# Path to the SQLite database file.  Can be a relative path or absolute.
# PHENODAG_DB=phenodag.db

# Logging
# Log level: debug | info | warn | error
# PHENODAG_LOG_LEVEL=info
# Log format: text | json
# PHENODAG_LOG_FORMAT=text

# Remote Claims DB (used by remote-claim subcommands)
# PHENODAG_REMOTE_CLAIMS_DB=FLEET_REMOTE_CLAIMS.db
